.env
__pycache__/
*.pyc
.pytest_cache/
.cache/
runs/*
!runs/.gitkeep
# Generated repair workspaces (proposals / apply / merges / staging) — never commit these.
harnesses/candidates/_repair_proposals/
harnesses/candidates/_repair_applications/
harnesses/candidates/_repair_merges/
harnesses/candidates/_staging_promotions/
# Generated dashboard snapshot (the .example.json is tracked; the live one is not).
ui_dashboard/data/dashboard_snapshot.json
# Imported review-package fixture candidates (operator-generated; never committed).
fixtures/openai_planner/imported_review_package_*/
# Human-approved imported fixtures (operator-generated; never committed).
fixtures/openai_planner/approved_imported_*/
node_modules/
dist/
build/
.coverage
.DS_Store
# Brownfield external sources: keep folders and manifests, ignore heavy raw inputs by default.
external/inbox/raw/*
!external/inbox/raw/.gitkeep
external/staging/*
!external/staging/.gitkeep
external/approved/*
!external/approved/.gitkeep
external/projects/*
!external/projects/.gitkeep
external/datasets/*
!external/datasets/.gitkeep
external/multimodal/*
!external/multimodal/.gitkeep
!external/inbox/manifests/
!external/inbox/manifests/*.yaml

# App build outputs
apps/**/node_modules/
apps/**/dist/
apps/**/.next/

# Python virtual env (never commit)
.venv/

# Secrets — defensive guard, NEVER commit credentials/keys/tokens.
# (Keep real secrets OUTSIDE the repo; this only stops accidental commits.)
password_and_api.txt
password*.txt
passwords*
*credentials*.json
*credentials*.txt
secrets.*
*secret*.txt
*secret*.json
*secret*.yaml
*secret*.yml
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.token
.env.*
!.env.example
*.env
secrets/
.secrets/

# Local config (generated; never commit). Keep example + schema tracked.
config/config.json
config/*.local.json
config/*.secret.json
config/secrets/
!config/config.example.json
!config/config.schema.json
