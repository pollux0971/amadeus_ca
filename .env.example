# Copy this file to .env only for local development.
# Never commit real secrets. .env is gitignored; .env.example is the template.
# Placeholders only — do NOT put a real key here.

# LLM provider selection. Default MUST be "fake" (no real API calls).
LLM_PROVIDER=fake

# API keys — leave EMPTY here; set real values only in a local .env / env vars.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model ids (optional placeholders).
OPENAI_MODEL=
ANTHROPIC_MODEL=

# Other local settings.
BROWSER_HEADLESS=true
AGENT_HARNESS_RUNS_DIR=runs
